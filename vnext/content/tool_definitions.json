[
  {
    "id": "basket",
    "displayName": "Basket",
    "capacity": 5
  },
  {
    "id": "settings",
    "displayName": "Settings",
    "capacity": 0
  },
  {
    "id": "pet_model_adapter",
    "displayName": "Pet Model Adapter",
    "capacity": 0,
    "defaultProvider": "none",
    "requiresFirstCallApproval": true,
    "apiKeyStorage": "windows-credential-manager",
    "modelCallDefault": "disabled",
    "helpers": [
      {
        "name": "Scout",
        "role": "ResearchHelper",
        "allowedToolFamilies": [
          "localDocs",
          "localResearch",
          "codeReview"
        ]
      },
      {
        "name": "Inspector",
        "role": "SpriteReviewHelper",
        "allowedToolFamilies": [
          "spriteAudit",
          "petState"
        ]
      },
      {
        "name": "Builder",
        "role": "ChecklistHelper",
        "allowedToolFamilies": [
          "codePatchPlan",
          "codeReview"
        ]
      }
    ]
  },
  {
    "id": "local_ai_research",
    "displayName": "Local AI Research",
    "capacity": 0,
    "defaultProvider": "deterministic-local",
    "ollamaProvider": {
      "endpointDefault": "http://127.0.0.1:11434",
      "modelDefault": "llama3.2:3b",
      "localhostOnly": true,
      "probePath": "/api/tags",
      "chatPath": "/v1/chat/completions"
    },
    "inProcessFallback": {
      "defaultState": "off",
      "setting": "local_runtime_inproc_enabled",
      "provider": "onnx-phi",
      "weightsFolder": "vnext/content/local-models/generation/phi-3-mini-4k-int4",
      "actualInferenceDeferred": true
    },
    "networkDefault": "disabled",
    "hostedAiDefault": "disabled",
    "outputs": [
      "research-evidence-packet",
      "source-records",
      "claims",
      "synthesis-report"
    ],
    "normalOperationRequiresHostedAi": false
  },
  {
    "id": "local_retrieval",
    "displayName": "Local Retrieval",
    "capacity": 0,
    "defaultState": "off",
    "toolFamily": "retrieval",
    "storage": "%LOCALAPPDATA%/Wevito/memory/<pet-id>.db",
    "keywordProvider": "sqlite-fts5-bm25",
    "denseProvider": "sqlite-vec-when-available-or-in-process-embedding",
    "fusion": "reciprocal-rank-fusion",
    "rrfK": 60,
    "rerankTopN": 8,
    "requiresUnifiedPolicyRead": true,
    "mayUseNetwork": false,
    "mayUseHostedAi": false,
    "mayMutateSourceFiles": false,
    "outputs": [
      "local-doc-ingest-manifest",
      "retrieval-result",
      "method-trace"
    ]
  },
  {
    "id": "golden_eval",
    "displayName": "Golden Eval",
    "capacity": 0,
    "defaultState": "off",
    "toolFamily": "learningEval",
    "datasetRoot": "vnext/content/local-ai/eval-golden",
    "requiresNetwork": false,
    "requiresHostedAi": false,
    "mayMutate": false,
    "baselineUpdateRequiresExplicitFlag": true,
    "regressionThresholds": {
      "recallAt1Drop": 0.02,
      "mrrDrop": 0.02,
      "citationCoverageDrop": 0.05,
      "citationCoverageFloor": 0.60
    }
  },
  {
    "id": "autonomous_scheduler",
    "displayName": "Autonomous Scheduler Preview",
    "capacity": 0,
    "defaultState": "off",
    "toolFamily": "scheduler",
    "allowedTriggers": [
      "stale_dashboard_report",
      "pending_reviewed_bundle",
      "failed_prior_proof_packet",
      "recurring_user_request"
    ],
    "outputs": [
      "scheduler-proposal",
      "draft-task-card",
      "run-summary"
    ],
    "mayDispatchAdapters": false,
    "mayExecute": false,
    "mayMutate": false
  },
  {
    "id": "pet_memory",
    "displayName": "Pet Memory",
    "capacity": 0,
    "defaultState": "off",
    "requiresWriteApproval": true,
    "storage": "%LOCALAPPDATA%/Wevito/memory/<pet-id>.db",
    "schemaVersion": "1",
    "vectorExtension": "sqlite-vec",
    "embeddingProviderDefault": "hashing-fallback",
    "embeddingProviderWhenOnnxActive": "bge-micro-v2",
    "embeddingDimensionsWhenOnnxActive": 384,
    "embeddingDimensionsWhenHashingFallback": 16,
    "localModelFolder": "vnext/content/local-models/embeddings/bge-micro-v2",
    "fallbackWhenUnavailable": "hashing-embedding"
  },
  {
    "id": "learning_eval",
    "displayName": "Learning Eval",
    "capacity": 0,
    "defaultState": "local-only",
    "networkDefault": "disabled",
    "hostedAiDefault": "disabled",
    "metrics": [
      "recall@1",
      "recall@3",
      "mrr",
      "latency_ms_p50",
      "latency_ms_p95"
    ],
    "regressionTolerance": 0.02,
    "outputs": [
      "eval-report",
      "run-summary",
      "eval-baseline"
    ]
  },
  {
    "id": "learning_promotion",
    "displayName": "Learning Promotion",
    "capacity": 0,
    "toolFamily": "learningPromotion",
    "defaultState": "approval-required",
    "requiresApprovedTaskCard": true,
    "automaticTrainingEnabled": false,
    "automaticMemoryPromotionEnabled": false,
    "copiesBinaryAssets": false,
    "outputs": [
      "learning-dataset-manifest",
      "examples-jsonl",
      "promotion-report"
    ]
  },
  {
    "id": "web_research",
    "displayName": "Approved Web Research",
    "capacity": 0,
    "toolFamily": "localResearch",
    "defaultBackend": "offline",
    "networkDefault": "disabled",
    "hostedAiDefault": "disabled",
    "requiresApprovedTaskCard": true,
    "credentialTargets": [
      "Wevito/web-search/brave",
      "Wevito/web-search/tavily",
      "Wevito/web-search/firecrawl"
    ],
    "rateLimits": {
      "maxFetchesPerHour": 30,
      "maxFetchesPerTask": 5
    },
    "outputs": [
      "web-fetch-records",
      "web-fetch-evidence-packet",
      "run-summary"
    ]
  },
  {
    "id": "local_tool_exec",
    "displayName": "Local Tool Execution Preview",
    "capacity": 0,
    "toolFamily": "localToolExec",
    "defaultState": "off",
    "pilotEnabled": false,
    "executionDefault": "blocked",
    "dryRunOnly": true,
    "allowedRoot": "tools/",
    "requiresSha256Allowlist": true,
    "outputs": [
      "local-tool-exec-preview-report",
      "run-summary"
    ]
  },
  {
    "id": "guarded_mutation",
    "displayName": "Guarded Mutation Preview",
    "capacity": 0,
    "toolFamily": "guardedMutation",
    "defaultState": "off",
    "executionDefault": "blocked",
    "dryRunOnly": true,
    "requiresApprovedTaskCardForApply": true,
    "outputs": [
      "guarded-mutation-preview",
      "run-summary"
    ]
  },
  {
    "id": "autonomous_beta_promotion",
    "displayName": "Autonomous Beta Promotion",
    "capacity": 0,
    "defaultState": "off",
    "toolFamily": "promotion",
    "requiresSevenDayEvidenceWindow": true,
    "entryRequiresDecision": "EnableAutonomousBeta",
    "entryRequiresKillSwitchOff": true,
    "entryRequiresCurrentBetaDisabled": true,
    "confirmationRequired": true,
    "outputs": [
      "promotion_criteria_snapshot",
      "promotion_decision",
      "runtime_autonomous_beta_user_consent"
    ]
  }
]
