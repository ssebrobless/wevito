<Window x:Class="Wevito.VNext.Shell.FirstLaunchWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="Welcome to Wevito"
        Width="500"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#171D23">
    <Border Padding="20"
            Background="#171D23">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Text="Set up Wevito"
                           Foreground="#FFF0F4F5"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="StepText"
                           Margin="0,4,0,0"
                           Foreground="#FFB6C7D1"
                           Text="Step 1 of 4" />
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Margin="0,18,0,18">
                <StackPanel x:Name="AiNameStepPanel">
                    <TextBlock Text="What should I call you?"
                               Foreground="#FFF0F4F5"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,10"
                               Text="This names the local AI assistant. The pets stay as the visual surface."
                               Foreground="#FFB6C7D1"
                               TextWrapping="Wrap" />
                    <TextBox x:Name="AiNameTextBox"
                             automation:AutomationProperties.AutomationId="FirstLaunchAiNameTextBox"
                             Text="Wevito" />
                </StackPanel>

                <StackPanel x:Name="AgentNamesStepPanel"
                            Visibility="Collapsed">
                    <TextBlock Text="What should I call your agents?"
                               Foreground="#FFF0F4F5"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,10"
                               Text="These are the three behind-the-scenes work slots. Pet animations stay normal."
                               Foreground="#FFB6C7D1"
                               TextWrapping="Wrap" />
                    <TextBox x:Name="AgentOneTextBox"
                             Margin="0,0,0,8"
                             automation:AutomationProperties.AutomationId="FirstLaunchAgentOneTextBox"
                             Text="Agent 1" />
                    <TextBox x:Name="AgentTwoTextBox"
                             Margin="0,0,0,8"
                             automation:AutomationProperties.AutomationId="FirstLaunchAgentTwoTextBox"
                             Text="Agent 2" />
                    <TextBox x:Name="AgentThreeTextBox"
                             automation:AutomationProperties.AutomationId="FirstLaunchAgentThreeTextBox"
                             Text="Agent 3" />
                </StackPanel>

                <StackPanel x:Name="BackgroundStepPanel"
                            Visibility="Collapsed">
                    <TextBlock Text="Want me to do anything in the background right now?"
                               Foreground="#FFF0F4F5"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <RadioButton x:Name="JustChatRadioButton"
                                 Margin="0,12,0,8"
                                 Foreground="#FFF0F4F5"
                                 IsChecked="True"
                                 Content="Just chat" />
                    <RadioButton x:Name="SpriteCleanupRadioButton"
                                 Margin="0,0,0,8"
                                 Foreground="#FFF0F4F5"
                                 Content="Help with sprite cleanup" />
                    <RadioButton x:Name="AddLaterRadioButton"
                                 Foreground="#FFF0F4F5"
                                 Content="Add later" />
                </StackPanel>

                <StackPanel x:Name="FirstChatStepPanel"
                            Visibility="Collapsed">
                    <TextBlock Text="First chat"
                               Foreground="#FFF0F4F5"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="GreetingText"
                               Margin="0,10,0,0"
                               Foreground="#FFB6C7D1"
                               TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="BackButton"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Content="Back"
                        IsEnabled="False"
                        Click="BackButton_OnClick" />
                <Button x:Name="NextButton"
                        Padding="12,6"
                        automation:AutomationProperties.AutomationId="FirstLaunchNextButton"
                        Content="Next"
                        Click="NextButton_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
