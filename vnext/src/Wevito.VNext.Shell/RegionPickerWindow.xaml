<Window x:Class="Wevito.VNext.Shell.RegionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Capture Region"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="#22000000"
        KeyDown="OnKeyDown"
        MouseDown="OnMouseDown"
        MouseMove="OnMouseMove"
        MouseUp="OnMouseUp">
    <Grid>
        <Border Background="#44000000" />
        <TextBlock x:Name="InstructionText"
                   Margin="24"
                   Padding="12,8"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Background="#CC0B1220"
                   Foreground="White"
                   FontSize="15"
                   Text="Drag to select a region. Press Esc to cancel." />
        <Canvas x:Name="SelectionCanvas"
                IsHitTestVisible="False">
            <Rectangle x:Name="SelectionRectangle"
                       Visibility="Collapsed"
                       Stroke="#FFE8F2FF"
                       StrokeThickness="2"
                       Fill="#33FFFFFF" />
        </Canvas>
    </Grid>
</Window>
