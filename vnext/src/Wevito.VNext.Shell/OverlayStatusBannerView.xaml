<UserControl x:Class="Wevito.VNext.Shell.OverlayStatusBannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             Height="28">
    <Border x:Name="BannerBorder"
            Padding="10,5"
            Background="#E61A2831"
            BorderBrush="#6E8998"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed"
            automation:AutomationProperties.AutomationId="OverlayStatusBanner">
        <TextBlock x:Name="BannerText"
                   Text="Last action: none yet · today: 0 previews, 0 approvals, 0 mutations"
                   Foreground="#FFEAF4F7"
                   FontSize="11"
                   TextTrimming="CharacterEllipsis" />
    </Border>
</UserControl>
