<Window x:Class="Wevito.VNext.Shell.RoamBandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wevito Roam Band"
        Width="1280"
        Height="118"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Grid IsHitTestVisible="False">
        <Canvas x:Name="RoamCanvas" />
        <local:OverlayStatusBannerView x:Name="StatusBanner"
                                       xmlns:local="clr-namespace:Wevito.VNext.Shell"
                                       Width="760"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,4,0,0" />
    </Grid>
</Window>
