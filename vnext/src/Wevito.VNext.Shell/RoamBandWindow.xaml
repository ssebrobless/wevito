        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wevito Roam Band"
        Width="1280"
        Height="118"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Grid IsHitTestVisible="False">
        <Canvas x:Name="RoamCanvas" />
    </Grid>
</Window>
