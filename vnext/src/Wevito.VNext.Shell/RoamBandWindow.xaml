<Window x:Class="Wevito.VNext.Shell.RoamBandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wevito Roam Band"
        Width="1280"
        Height="118"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Grid IsHitTestVisible="False">
        <Canvas x:Name="RoamCanvas" />
        <Border x:Name="GhostNamePopup"
                Visibility="Collapsed"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#E61F242A"
                BorderBrush="#CCFFFFFF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8,3">
            <TextBlock x:Name="GhostNameText"
                       Foreground="#FFFFFFFF"
                       FontSize="11"
                       FontWeight="SemiBold" />
        </Border>
        <local:OverlayStatusBannerView x:Name="StatusBanner"
                                       xmlns:local="clr-namespace:Wevito.VNext.Shell"
                                       Width="760"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,4,0,0" />
    </Grid>
</Window>
