<Window x:Class="Wevito.VNext.Shell.HomePanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="Wevito Home Panel"
        Width="392"
        Height="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Border x:Name="PanelBorder"
            Background="#F61B2228"
            BorderBrush="#FF72858B"
            BorderThickness="1"
            CornerRadius="18"
            Padding="12"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <StackPanel>
            <Grid x:Name="HeaderPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="TitleText"
                               Text="Wevito"
                               Foreground="#FFF1F3F4"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SubtitleText"
                               Margin="0,2,0,0"
                               Text="Corner habitat online"
                               Foreground="#FFD4DADC"
                               FontSize="11" />
                </StackPanel>

                <Button x:Name="PinButton"
                        Grid.Column="1"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        automation:AutomationProperties.AutomationId="PinButton"
                        Content="PIN"
                        Click="PinButton_OnClick" />
                <Button x:Name="BasketButton"
                        Grid.Column="2"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        automation:AutomationProperties.AutomationId="BasketButton"
                        Content="BIN"
                        Click="BasketButton_OnClick" />
                <Button x:Name="CaptureButton"
                        Grid.Column="3"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        automation:AutomationProperties.AutomationId="CaptureButton"
                        Content="CAP"
                        Click="CaptureButton_OnClick" />
                <Button x:Name="SettingsButton"
                        Grid.Column="4"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        automation:AutomationProperties.AutomationId="SettingsButton"
                        Content="SET"
                        Click="SettingsButton_OnClick" />
                <Button x:Name="CompactButton"
                        Grid.Column="5"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        automation:AutomationProperties.AutomationId="CompactButton"
                        Content="MIN"
                        Click="CompactButton_OnClick" />
                <Button x:Name="SaveButton"
                        Grid.Column="6"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        automation:AutomationProperties.AutomationId="SaveButton"
                        Content="SAVE"
                        Click="SaveButton_OnClick" />
            </Grid>

            <TextBlock x:Name="ModeText"
                       Margin="0,10,0,10"
                       Foreground="#FFCCE18D"
                       FontSize="11"
                       Text="Focused" />

            <Border x:Name="StageBorder"
                    CornerRadius="14"
                    Background="#FF52616B"
                    BorderBrush="#FF92A6A6"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="22" />
                    </Grid.RowDefinitions>
                    <Image x:Name="StageBackgroundImage"
                           Grid.RowSpan="2"
                           Stretch="Fill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                    <Rectangle x:Name="StageGradient"
                               Grid.RowSpan="2"
                               RadiusX="14"
                               RadiusY="14"
                               Fill="#88434F57" />
                    <Image x:Name="CelestialImage"
                           Width="28"
                           Height="28"
                           Margin="0,10,10,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                    <Canvas x:Name="HomePetCanvas"
                            Margin="0,0,0,10" />
                    <Border x:Name="EnvironmentChrome"
                            Grid.Row="1"
                            Background="#AA2F3B41"
                            CornerRadius="0,0,14,14">
                        <TextBlock x:Name="EnvironmentLabel"
                                   Margin="12,0"
                                   VerticalAlignment="Center"
                                   Foreground="#FFE6ECEF"
                                   FontSize="11"
                                   Text="Corner Garden" />
                    </Border>
                </Grid>
            </Border>

            <StackPanel x:Name="StatusPanel"
                        Margin="0,10,0,0">
                <TextBlock x:Name="StatusText"
                           Foreground="#FFE1E6E9"
                           FontSize="11"
                           Text="3 pets active" />
                <WrapPanel x:Name="StatusIconPanel"
                           Margin="0,6,0,0" />
                <WrapPanel x:Name="RecommendedItemPanel"
                           Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel x:Name="HudPanel"
                        Margin="0,10,0,0">
                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Hunger"
                                   Foreground="#FFF0F4F5"
                                   FontSize="10" />
                        <ProgressBar x:Name="HungerBar"
                                     Height="10"
                                     Maximum="100"
                                     Value="80" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Thirst"
                                   Foreground="#FFF0F4F5"
                                   FontSize="10" />
                        <ProgressBar x:Name="ThirstBar"
                                     Height="10"
                                     Maximum="100"
                                     Value="80" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Energy"
                                   Foreground="#FFF0F4F5"
                                   FontSize="10" />
                        <ProgressBar x:Name="EnergyBar"
                                     Height="10"
                                     Maximum="100"
                                     Value="80" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Clean"
                                   Foreground="#FFF0F4F5"
                                   FontSize="10" />
                        <ProgressBar x:Name="CleanlinessBar"
                                     Height="10"
                                     Maximum="100"
                                     Value="80" />
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Margin="0,8,0,0"
                             Columns="3"
                             Rows="3">
                    <Button x:Name="FeedButton"
                            Margin="0,0,6,6"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="FeedButton"
                            Click="FeedButton_OnClick">
                        <StackPanel>
                            <Image x:Name="FeedIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Feed"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="WaterButton"
                            Margin="0,0,6,6"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="WaterButton"
                            Click="WaterButton_OnClick">
                        <StackPanel>
                            <Image x:Name="WaterIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Water"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RestButton"
                            Margin="0,0,0,6"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="RestButton"
                            Click="RestButton_OnClick">
                        <StackPanel>
                            <Image x:Name="RestIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Rest"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="PlayButton"
                            Margin="0,0,6,6"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="PlayButton"
                            Click="PlayButton_OnClick">
                        <StackPanel>
                            <Image x:Name="PlayIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Play"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="GroomButton"
                            Margin="0,0,6,6"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="GroomButton"
                            Click="GroomButton_OnClick">
                        <StackPanel>
                            <Image x:Name="GroomIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Groom"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BathButton"
                            Margin="0,0,0,6"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="BathButton"
                            Click="BathButton_OnClick">
                        <StackPanel>
                            <Image x:Name="BathIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Bath"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="MedicineButton"
                            Margin="0,0,6,0"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="MedicineButton"
                            Click="MedicineButton_OnClick">
                        <StackPanel>
                            <Image x:Name="MedicineIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Medicine"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="DoctorButton"
                            Margin="0,0,6,0"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="DoctorButton"
                            Click="DoctorButton_OnClick">
                        <StackPanel>
                            <Image x:Name="DoctorIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Doctor"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="HomeButton"
                            Padding="6,4"
                            automation:AutomationProperties.AutomationId="HomeButton"
                            Click="HomeButton_OnClick">
                        <StackPanel>
                            <Image x:Name="HomeIcon"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Home"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </StackPanel>

            <TextBlock x:Name="FeedbackText"
                       Margin="0,12,0,0"
                       Foreground="#FFF3C969"
                       FontSize="11"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
