<Window x:Class="Wevito.VNext.Shell.HomePanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wevito Home Panel"
        Width="360"
        Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Border x:Name="PanelBorder"
            Background="#E4222830"
            BorderBrush="#FF6A7A82"
            BorderThickness="1"
            CornerRadius="18"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="132" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="TitleText"
                               Text="Wevito"
                               Foreground="#FFF1F3F4"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SubtitleText"
                               Margin="0,2,0,0"
                               Text="Corner habitat online"
                               Foreground="#FFD4DADC"
                               FontSize="11" />
                </StackPanel>

                <Button x:Name="PinButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        Content="PIN"
                        Click="PinButton_OnClick" />
                <Button x:Name="BasketButton"
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        Content="BIN"
                        Click="BasketButton_OnClick" />
                <Button x:Name="CaptureButton"
                        Grid.Column="3"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        Content="CAP"
                        Click="CaptureButton_OnClick" />
            </Grid>

            <TextBlock x:Name="ModeText"
                       Grid.Row="1"
                       Margin="0,10,0,10"
                       Foreground="#FFCCE18D"
                       FontSize="11"
                       Text="Focused" />

            <Border Grid.Row="2"
                    CornerRadius="14"
                    Background="#FF52616B"
                    BorderBrush="#FF92A6A6"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="22" />
                    </Grid.RowDefinitions>
                    <Rectangle x:Name="StageGradient"
                               Grid.RowSpan="2"
                               RadiusX="14"
                               RadiusY="14"
                               Fill="#FF52616B" />
                    <Canvas x:Name="HomePetCanvas"
                            Margin="0,0,0,10" />
                    <Border Grid.Row="1"
                            Background="#AA2F3B41"
                            CornerRadius="0,0,14,14">
                        <TextBlock x:Name="EnvironmentLabel"
                                   Margin="12,0"
                                   VerticalAlignment="Center"
                                   Foreground="#FFE6ECEF"
                                   FontSize="11"
                                   Text="Corner Garden" />
                    </Border>
                </Grid>
            </Border>

            <StackPanel x:Name="HudPanel"
                        Grid.Row="3"
                        Margin="0,12,0,0">
                <TextBlock x:Name="StatusText"
                           Foreground="#FFE1E6E9"
                           FontSize="11"
                           Text="3 pets • basket ready" />
                <UniformGrid Margin="0,10,0,0"
                             Columns="3">
                    <Button Margin="0,0,6,0"
                            Padding="8,5"
                            Content="Feed"
                            Click="FeedButton_OnClick" />
                    <Button Margin="0,0,6,0"
                            Padding="8,5"
                            Content="Pet"
                            Click="PetButton_OnClick" />
                    <Button Padding="8,5"
                            Content="Rest"
                            Click="RestButton_OnClick" />
                </UniformGrid>
            </StackPanel>

            <TextBlock x:Name="FeedbackText"
                       Grid.Row="4"
                       Margin="0,12,0,0"
                       Foreground="#FFF3C969"
                       FontSize="11"
                       TextWrapping="Wrap" />
        </Grid>
    </Border>
</Window>
