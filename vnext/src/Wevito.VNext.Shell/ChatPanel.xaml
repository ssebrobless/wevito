<UserControl x:Class="Wevito.VNext.Shell.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             MinHeight="340">
    <UserControl.Resources>
        <Style x:Key="ChatButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF0F4F5" />
            <Setter Property="Background" Value="#263844" />
            <Setter Property="BorderBrush" Value="#52656F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="NewChatButton"
                    Grid.Column="0"
                    Padding="8,4"
                    Margin="0,0,6,0"
                    Style="{StaticResource ChatButtonStyle}"
                    automation:AutomationProperties.AutomationId="ChatNewButton"
                    Content="New Chat"
                    Click="NewChatButton_OnClick" />
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Padding="8,5"
                     Background="#111A20"
                     BorderBrush="#4A6672"
                     Foreground="#FFF0F4F5"
                     CaretBrush="#FFF0F4F5"
                     automation:AutomationProperties.AutomationId="ChatSearchTextBox"
                     ToolTip="Search local chat history" />
            <Button x:Name="SearchButton"
                    Grid.Column="2"
                    Padding="8,4"
                    Margin="6,0,0,0"
                    Style="{StaticResource ChatButtonStyle}"
                    automation:AutomationProperties.AutomationId="ChatSearchButton"
                    Content="Search"
                    Click="SearchButton_OnClick" />
            <Button x:Name="StopButton"
                    Grid.Column="3"
                    Padding="8,4"
                    Margin="6,0,0,0"
                    Style="{StaticResource ChatButtonStyle}"
                    automation:AutomationProperties.AutomationId="ChatStopButton"
                    Content="Stop"
                    Click="StopButton_OnClick" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,8,0,8"
                Background="#101920"
                BorderBrush="#344A56"
                BorderThickness="1"
                CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="MessageList"
                              Margin="8"
                              automation:AutomationProperties.AutomationId="ChatMessageList"
                              ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="8"
                                    Background="#17242D"
                                    BorderBrush="#2F4653"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding Header}"
                                                   DockPanel.Dock="Left"
                                                   Foreground="#FFEAF6F7"
                                                   FontWeight="SemiBold"
                                                   FontSize="11" />
                                        <Button Content="Bookmark for benchmark"
                                                DockPanel.Dock="Right"
                                                HorizontalAlignment="Right"
                                                Padding="6,2"
                                                Style="{StaticResource ChatButtonStyle}"
                                                FontSize="10"
                                                ToolTip="Benchmark bookmarking is wired in C-PHASE 113." />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Content}"
                                               Margin="0,5,0,0"
                                               Foreground="#FFD8E7EA"
                                               TextWrapping="Wrap"
                                               FontSize="12" />
                                    <Expander Header="tool details"
                                              Margin="0,5,0,0"
                                              Foreground="#FFB8CED6">
                                        <TextBlock Text="{Binding ToolCallJson}"
                                                   Foreground="#FFB8CED6"
                                                   TextWrapping="Wrap"
                                                   FontSize="10" />
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputTextBox"
                         Grid.Column="0"
                         MinHeight="44"
                         Padding="8,6"
                         Background="#111A20"
                         BorderBrush="#4A6672"
                         Foreground="#FFF0F4F5"
                         CaretBrush="#FFF0F4F5"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         automation:AutomationProperties.AutomationId="ChatInputTextBox"
                         ToolTip="Ask Wevito to help locally" />
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Padding="12,5"
                        Style="{StaticResource ChatButtonStyle}"
                        automation:AutomationProperties.AutomationId="ChatSendButton"
                        Content="Send"
                        Click="SendButton_OnClick" />
            </Grid>
            <TextBlock x:Name="StatusText"
                       Grid.Row="1"
                       Margin="0,5,0,0"
                       Foreground="#FFB8CED6"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Text="{Binding StatusText}" />
        </Grid>
    </Grid>
</UserControl>
