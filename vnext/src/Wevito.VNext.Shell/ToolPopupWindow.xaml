                                        automation:AutomationProperties.AutomationId="GuardedMutationPilotButton"
                                        Content="PROPOSE" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <TextBlock Margin="0,5,0,0"
                                   Foreground="#FFE1D6A8"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Text="Safety: PET TASKS is report-first. Most cards cannot run. Approved execution is limited to the small allowlist shown above and never imports/generates/mutates sprites from this surface." />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="DevPanel"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="Button"
                               BasedOn="{StaticResource PopupButtonStyle}" />
                        <Style TargetType="ComboBox"
                               BasedOn="{StaticResource PopupComboBoxStyle}" />
                        <Style TargetType="CheckBox"
                               BasedOn="{StaticResource PopupCheckBoxStyle}" />
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFD6DCDE" />
                        </Style>
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <TextBlock Text="Debug controls for scenario testing. These are for development builds only."
                                   Foreground="#FFD6DCDE"
                                   FontSize="11"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,12,0,4"
                                   Text="Selected pet"
                                   Foreground="#FFF0F4F5"
                                   FontSize="11" />
                        <ComboBox x:Name="SelectedPetComboBox"
                                  automation:AutomationProperties.AutomationId="SelectedPetComboBox"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Id"
                                  SelectionChanged="SelectedPetComboBox_OnSelectionChanged" />

                        <UniformGrid Margin="0,8,0,0"
                                     Columns="3">
                            <Button x:Name="AddPetButton"
                                    Margin="0,0,6,0"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="AddPetButton"
                                    Content="Add Pet"
                                    Click="AddPetButton_OnClick" />
                            <Button x:Name="RemovePetButton"
                                    Margin="0,0,6,0"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="RemovePetButton"
                                    Content="Remove Pet"
                                    Click="RemovePetButton_OnClick" />
                            <Button x:Name="ClearPetsButton"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="ClearPetsButton"
                                    Content="Clear All"
                                    Click="ClearPetsButton_OnClick" />
                        </UniformGrid>

                        <TextBlock Margin="0,12,0,4"
                                   Text="Appearance"
                                   Foreground="#FFF0F4F5"
                                   FontSize="11" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,6,6">
                                <TextBlock Text="Species"
                                           Foreground="#FFD6DCDE"
                                           FontSize="10" />
                                <ComboBox x:Name="SpeciesComboBox"
                                          automation:AutomationProperties.AutomationId="SpeciesComboBox"
                                          SelectionChanged="SpeciesComboBox_OnSelectionChanged" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,6">
                                <TextBlock Text="Color"
                                           Foreground="#FFD6DCDE"
                                           FontSize="10" />
                                <ComboBox x:Name="ColorComboBox"
                                          automation:AutomationProperties.AutomationId="ColorComboBox" />
                            </StackPanel>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Age"
                                           Foreground="#FFD6DCDE"
                                           FontSize="10" />
                                <ComboBox x:Name="AgeComboBox"
                                          automation:AutomationProperties.AutomationId="AgeComboBox" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Gender"
                                           Foreground="#FFD6DCDE"
                                           FontSize="10" />
                                <ComboBox x:Name="GenderComboBox"
                                          automation:AutomationProperties.AutomationId="GenderComboBox" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Margin="0,8,0,0"
                                     Columns="2">
                            <Button x:Name="ApplyAppearanceButton"
                                    Margin="0,0,6,0"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="ApplyAppearanceButton"
                                    Content="Apply Appearance"
                                    Click="ApplyAppearanceButton_OnClick" />
                            <Button x:Name="SpawnColorSetButton"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="SpawnColorSetButton"
                                    Content="Spawn Colors"
                                    Click="SpawnColorSetButton_OnClick" />
                        </UniformGrid>

                        <TextBlock Margin="0,12,0,4"
                                   Text="Environment"
                                   Foreground="#FFF0F4F5"
                                   FontSize="11" />
                        <UniformGrid Columns="2">
                            <ComboBox x:Name="EnvironmentComboBox"
                                      Margin="0,0,6,0"
                                      automation:AutomationProperties.AutomationId="EnvironmentComboBox"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Id" />
                            <Button x:Name="ApplyEnvironmentButton"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="ApplyEnvironmentButton"
                                    Content="Apply Env"
                                    Click="ApplyEnvironmentButton_OnClick" />
                        </UniformGrid>

                        <TextBlock Margin="0,12,0,4"
                                   Text="Animation lab"
                                   Foreground="#FFF0F4F5"
                                   FontSize="11" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Animation"
                                           Foreground="#FFD6DCDE"
                                           FontSize="10" />
                                <ComboBox x:Name="AnimationComboBox"
                                          automation:AutomationProperties.AutomationId="AnimationComboBox" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Seconds"
                                           Foreground="#FFD6DCDE"
                                           FontSize="10" />
                                <ComboBox x:Name="AnimationDurationComboBox"
                                          automation:AutomationProperties.AutomationId="AnimationDurationComboBox" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Margin="0,8,0,0"
                                     Columns="2">
                            <Button x:Name="ApplyAnimationButton"
                                    Margin="0,0,6,0"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="ApplyAnimationButton"
                                    Content="Force Anim"
                                    Click="ApplyAnimationButton_OnClick" />
                            <Button x:Name="ClearAnimationButton"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="ClearAnimationButton"
                                    Content="Clear Anim"
                                    Click="ClearAnimationButton_OnClick" />
                        </UniformGrid>

                        <TextBlock Margin="0,12,0,4"
                                   Text="Condition lab"
                                   Foreground="#FFF0F4F5"
                                   FontSize="11" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Condition"
                                           Foreground="#FFD6DCDE"
                                           FontSize="10" />
                                <ComboBox x:Name="ConditionComboBox"
                                          automation:AutomationProperties.AutomationId="ConditionComboBox" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Severity"
                                           Foreground="#FFD6DCDE"
                                           FontSize="10" />
                                <ComboBox x:Name="ConditionSeverityComboBox"
                                          automation:AutomationProperties.AutomationId="ConditionSeverityComboBox" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Margin="0,8,0,0"
                                     Columns="2">
                            <Button x:Name="ApplyConditionButton"
                                    Margin="0,0,6,0"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="ApplyConditionButton"
                                    Content="Set Condition"
                                    Click="ApplyConditionButton_OnClick" />
                            <Button x:Name="ClearConditionButton"
                                    Padding="8,5"
                                    automation:AutomationProperties.AutomationId="ClearConditionButton"
                                    Content="Clear Condition"
                                    Click="ClearConditionButton_OnClick" />
                        </UniformGrid>

                        <TextBlock Margin="0,12,0,4"
                                   Text="Quick presets"
                                   Foreground="#FFF0F4F5"
                                   FontSize="11" />
                        <WrapPanel>
                            <Button x:Name="HungryPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Hungry"
                                    Click="HungryPresetButton_OnClick" />
                            <Button x:Name="ThirstyPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Thirsty"
                                    Click="ThirstyPresetButton_OnClick" />
                            <Button x:Name="TiredPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Tired"
                                    Click="TiredPresetButton_OnClick" />
                            <Button x:Name="DirtyPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Dirty"
                                    Click="DirtyPresetButton_OnClick" />
                            <Button x:Name="LonelyPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Lonely"
                                    Click="LonelyPresetButton_OnClick" />
                            <Button x:Name="SickPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Sick"
                                    Click="SickPresetButton_OnClick" />
                            <Button x:Name="HealthyPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Healthy"
                                    Click="HealthyPresetButton_OnClick" />
                            <Button x:Name="ComfortedPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Comforted"
                                    Click="ComfortedPresetButton_OnClick" />
                            <Button x:Name="RecallPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Recall"
                                    Click="RecallPresetButton_OnClick" />
                            <Button x:Name="ObesePresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Obese"
                                    Click="ObesePresetButton_OnClick" />
                            <Button x:Name="MalnourishedPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Malnourish"
                                    Click="MalnourishedPresetButton_OnClick" />
                            <Button x:Name="AnxiousPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Anxious"
                                    Click="AnxiousPresetButton_OnClick" />
                            <Button x:Name="DepressedPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Depressed"
                                    Click="DepressedPresetButton_OnClick" />
                            <Button x:Name="InjuredPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Injured"
                                    Click="InjuredPresetButton_OnClick" />
                            <Button x:Name="ElderPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Elder"
                                    Click="ElderPresetButton_OnClick" />
                            <Button x:Name="FoodiePresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Foodie"
                                    Click="FoodiePresetButton_OnClick" />
                            <Button x:Name="CuddlyPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Cuddly"
                                    Click="CuddlyPresetButton_OnClick" />
                            <Button x:Name="NeatPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Neat"
                                    Click="NeatPresetButton_OnClick" />
                            <Button x:Name="PlayfulPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Playful"
                                    Click="PlayfulPresetButton_OnClick" />
                            <Button x:Name="StubbornPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Stubborn"
                                    Click="StubbornPresetButton_OnClick" />
                            <Button x:Name="ResilientPresetButton"
                                    Margin="0,0,6,6"
                                    Padding="8,4"
                                    Content="Resilient"
                                    Click="ResilientPresetButton_OnClick" />
                        </WrapPanel>

                        <TextBlock Margin="0,12,0,4"
                                   Text="Long-term state"
                                   Foreground="#FFF0F4F5"
                                   FontSize="11" />
                        <TextBlock x:Name="PersonalitySummaryText"
                                   Foreground="#FFD6DCDE"
                                   FontSize="10"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="HabitSummaryText"
                                   Margin="0,4,0,0"
                                   Foreground="#FFD6DCDE"
                                   FontSize="10"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="AgingSummaryText"
                                   Margin="0,4,0,0"
                                   Foreground="#FFD6DCDE"
                                   FontSize="10"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="ConditionSummaryText"
                                   Margin="0,4,0,0"
                                   Foreground="#FFD6DCDE"
                                   FontSize="10"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,12,0,4"
                                   Text="Vitals"
                                   Foreground="#FFF0F4F5"
                                   FontSize="11" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="74" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Hunger" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="HungerSlider" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="HungerValueText" Grid.Row="0" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Text="Thirst" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="ThirstSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="ThirstValueText" Grid.Row="1" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Text="Energy" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="EnergySlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="EnergyValueText" Grid.Row="2" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="3" Text="Clean" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="CleanlinessSlider" Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="CleanlinessValueText" Grid.Row="3" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="4" Text="Affect" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="AffectionSlider" Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="AffectionValueText" Grid.Row="4" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="5" Text="Comfort" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="ComfortSlider" Grid.Row="5" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="ComfortValueText" Grid.Row="5" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="6" Text="Health" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="HealthSlider" Grid.Row="6" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="HealthValueText" Grid.Row="6" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="7" Text="Fitness" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="FitnessSlider" Grid.Row="7" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="FitnessValueText" Grid.Row="7" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="8" Text="Bio Age" Foreground="#FFD6DCDE" FontSize="10" />
                            <Slider x:Name="BiologicalAgeSlider" Grid.Row="8" Grid.Column="1" Minimum="0" Maximum="720" TickFrequency="15" IsSnapToTickEnabled="False" />
                            <TextBlock x:Name="BiologicalAgeValueText" Grid.Row="8" Grid.Column="2" Foreground="#FFF0F4F5" FontSize="10" VerticalAlignment="Center" />
                        </Grid>

                        <Button x:Name="ApplyVitalsButton"
                                Margin="0,10,0,0"
                                Padding="8,5"
                                automation:AutomationProperties.AutomationId="ApplyVitalsButton"
                                Content="Apply Vitals"
                                Click="ApplyVitalsButton_OnClick" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <UniformGrid x:Name="BasketButtons"
                         Grid.Row="2"
                         Columns="2">
                <Button x:Name="PasteButton"
                        Margin="0,0,6,0"
                        Style="{StaticResource PopupButtonStyle}"
                        automation:AutomationProperties.AutomationId="PasteButton"
                        Content="PASTE"
                        Click="PasteButton_OnClick" />
                <Button x:Name="DeleteButton"
                        Style="{StaticResource PopupDangerButtonStyle}"
                        automation:AutomationProperties.AutomationId="DeleteButton"
                        Content="DELETE"
                        Click="DeleteButton_OnClick" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>
