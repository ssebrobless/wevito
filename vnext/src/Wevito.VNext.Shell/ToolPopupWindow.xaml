<Window x:Class="Wevito.VNext.Shell.ToolPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        xmlns:local="clr-namespace:Wevito.VNext.Shell"
        Title="Wevito Basket"
        Width="450"
        Height="344"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowDrop="True"
        Drop="ToolPopupWindow_OnDrop">
    <Window.Resources>
        <Style x:Key="PopupButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF0F4F5" />
            <Setter Property="Background" Value="#20394A" />
            <Setter Property="BorderBrush" Value="#5F88A1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupDangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PopupButtonStyle}">
            <Setter Property="Background" Value="#3D2626" />
            <Setter Property="BorderBrush" Value="#8E5B5B" />
        </Style>

        <Style x:Key="PopupMiniButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PopupButtonStyle}">
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <Style x:Key="PopupComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFF0F4F5" />
            <Setter Property="Background" Value="#1A2831" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#284455" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#305569" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFF0F4F5" />
            <Setter Property="Background" Value="#1A2831" />
            <Setter Property="BorderBrush" Value="#52656F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource PopupComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="28" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <Border Grid.Column="1"
                                            Background="#243640"
                                            BorderBrush="#52656F"
                                            BorderThickness="1,0,0,0"
                                            CornerRadius="0,4,4,0">
                                        <Path HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Fill="#FFD9E5EA"
                                              Data="M 0 0 L 4 4 L 8 0 Z" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#1A2831"
                                        BorderBrush="#52656F"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ScrollViewer MaxHeight="240"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#7FA2B5" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#9AC4D8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFF0F4F5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder"
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    Background="#1A2831"
                                    BorderBrush="#52656F"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <Path x:Name="CheckMark"
                                      Data="M 2 8 L 6 12 L 13 3"
                                      Stroke="#FFF0F4F5"
                                      StrokeThickness="2"
                                      Stretch="Fill"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#24465A" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#7FA2B5" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#F61F242A"
            BorderBrush="#FF86939B"
            BorderThickness="1"
            CornerRadius="16"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="PopupTitle"
                           Text="Basket"
                           Foreground="#FFF0F4F5"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <Border x:Name="PetTaskReportOnlyBadge"
                        Grid.Column="1"
                        Margin="0,0,8,0"
                        Padding="8,3"
                        Background="#263B2F"
                        BorderBrush="#79A980"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="Collapsed">
                    <TextBlock Text="REPORT ONLY"
                               automation:AutomationProperties.AutomationId="PetTaskReportOnlyBadge"
                               Foreground="#FFE7F8DF"
                               FontSize="10"
                               FontWeight="Bold" />
                </Border>
                <Button x:Name="CloseButton"
                        Grid.Column="2"
                        Padding="10,4"
                        Style="{StaticResource PopupButtonStyle}"
                        automation:AutomationProperties.AutomationId="ToolCloseButton"
                        Content="Close"
                        Click="CloseButton_OnClick" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,10,0,10">
                <Grid x:Name="BasketPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="BasketSummaryText"
                               Margin="0,0,0,8"
                               Foreground="#FFD6DCDE"
                               FontSize="11"
                               Text="Saved links appear here." />

                    <DataGrid x:Name="BasketGrid"
                              Grid.Row="1"
                              automation:AutomationProperties.AutomationId="BasketGrid"
                              MouseDoubleClick="BasketGrid_OnMouseDoubleClick"
                              SelectionChanged="BasketGrid_OnSelectionChanged"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserReorderColumns="False"
                              IsReadOnly="False"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              RowHeight="32"
                              ColumnHeaderHeight="28"
                              Background="#192026"
                              BorderBrush="#44525A"
                              BorderThickness="1"
                              AlternatingRowBackground="#12272E"
                              RowBackground="#0E1A20">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#203039" />
                                <Setter Property="Foreground" Value="#FFF0F4F5" />
                                <Setter Property="BorderBrush" Value="#44525A" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="8,5" />
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="#FFF0F4F5" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#0E1A20" />
                                <Setter Property="Foreground" Value="#FFF0F4F5" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#12303A" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A3946" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsMarked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="44"
                                                    Header="DEL" />
                            <DataGridTemplateColumn Header="LINK"
                                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                HorizontalAlignment="Left"
                                                HorizontalContentAlignment="Left"
                                                automation:AutomationProperties.AutomationId="BasketLinkButton"
                                                Tag="{Binding Id}"
                                                Click="BasketLinkButton_OnClick">
                                            <TextBlock Text="{Binding Label}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="12"
                                                       Foreground="#FFBFE7FF" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="HOST"
                                                    Width="112"
                                                    IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#20313A"
                                                BorderBrush="#4A6672"
                                                BorderThickness="1"
                                                CornerRadius="9"
                                                Padding="6,2"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Host}"
                                                       FontSize="10"
                                                       Foreground="#FFE7EEF1" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="SAVED"
                                                    Width="86"
                                                    IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CapturedLabel}"
                                                   FontSize="10"
                                                   Foreground="#FFB7C4C9"
                                                   HorizontalAlignment="Right" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid x:Name="ActionPanel"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ActionSummaryText"
                               Margin="0,0,0,8"
                               Foreground="#FFD6DCDE"
                               FontSize="11"
                               Text="Choose an item for this action." />

                    <DataGrid x:Name="ActionGrid"
                              Grid.Row="1"
                              automation:AutomationProperties.AutomationId="ActionGrid"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserReorderColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              PreviewMouseMove="ActionGrid_OnPreviewMouseMove"
                              RowHeight="38"
                              ColumnHeaderHeight="28"
                              Background="#192026"
                              BorderBrush="#44525A"
                              BorderThickness="1"
                              AlternatingRowBackground="#12272E"
                              RowBackground="#0E1A20">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#203039" />
                                <Setter Property="Foreground" Value="#FFF0F4F5" />
                                <Setter Property="BorderBrush" Value="#44525A" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="8,5" />
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="#FFF0F4F5" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#0E1A20" />
                                <Setter Property="Foreground" Value="#FFF0F4F5" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#12303A" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A3946" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="TARGET"
                                                    Width="112">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Padding="8,3"
                                                Style="{StaticResource PopupMiniButtonStyle}"
                                                automation:AutomationProperties.AutomationId="ActionOptionButton"
                                                automation:AutomationProperties.Name="{Binding ButtonLabel}"
                                                Tag="{Binding Key}"
                                                Click="ActionOptionButton_OnClick"
                                                Content="{Binding ButtonLabel}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="ITEM"
                                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Preview}"
                                                   Width="28"
                                                   Height="28"
                                                   Margin="0,0,8,0"
                                                   SnapsToDevicePixels="True"
                                                   UseLayoutRounding="True"
                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                   RenderOptions.EdgeMode="Aliased" />
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="12"
                                                           Foreground="#FFF0F4F5" />
                                                <TextBlock Text="{Binding DetailLabel}"
                                                           FontSize="10"
                                                           Foreground="#FFB7C4C9" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="TYPE"
                                                    Width="86">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#20313A"
                                                BorderBrush="#4A6672"
                                                BorderThickness="1"
                                                CornerRadius="9"
                                                Padding="6,2"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding CategoryLabel}"
                                                       FontSize="10"
                                                       Foreground="#FFE7EEF1" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <StackPanel x:Name="ActionMenuPanel"
                            Visibility="Collapsed">
                    <TextBlock x:Name="ActionMenuSummaryText"
                               Margin="0,0,0,8"
                               Foreground="#FFD6DCDE"
                               FontSize="11"
                               Text="Choose an action to open its prepared options." />
                    <UniformGrid Columns="3"
                                 Rows="3">
                        <Button x:Name="ActionMenuFeedButton"
                                Margin="0,0,6,6"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuFeedButton"
                                Content="Feed"
                                Click="ActionMenuButton_OnClick"
                                Tag="feed" />
                        <Button x:Name="ActionMenuWaterButton"
                                Margin="0,0,6,6"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuWaterButton"
                                Content="Water"
                                Click="ActionMenuButton_OnClick"
                                Tag="water" />
                        <Button x:Name="ActionMenuRestButton"
                                Margin="0,0,0,6"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuRestButton"
                                Content="Rest"
                                Click="ActionMenuButton_OnClick"
                                Tag="rest" />
                        <Button x:Name="ActionMenuPlayButton"
                                Margin="0,0,6,6"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuPlayButton"
                                Content="Play"
                                Click="ActionMenuButton_OnClick"
                                Tag="play" />
                        <Button x:Name="ActionMenuGroomButton"
                                Margin="0,0,6,6"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuGroomButton"
                                Content="Groom"
                                Click="ActionMenuButton_OnClick"
                                Tag="groom" />
                        <Button x:Name="ActionMenuBathButton"
                                Margin="0,0,0,6"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuBathButton"
                                Content="Bath"
                                Click="ActionMenuButton_OnClick"
                                Tag="bath" />
                        <Button x:Name="ActionMenuMedicineButton"
                                Margin="0,0,6,0"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuMedicineButton"
                                Content="Medicine"
                                Click="ActionMenuButton_OnClick"
                                Tag="medicine" />
                        <Button x:Name="ActionMenuDoctorButton"
                                Margin="0,0,6,0"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuDoctorButton"
                                Content="Doctor"
                                Click="ActionMenuButton_OnClick"
                                Tag="doctor" />
                        <Button x:Name="ActionMenuHomeButton"
                                Style="{StaticResource PopupButtonStyle}"
                                automation:AutomationProperties.AutomationId="ActionMenuHomeButton"
                                Content="Home"
                                Click="ActionMenuButton_OnClick"
                                Tag="home" />
                    </UniformGrid>
                </StackPanel>

                <StackPanel x:Name="SettingsPanel"
                            Visibility="Collapsed">
                    <TextBlock Text="Tune the local HUD without affecting the passive roam behavior."
                               Foreground="#FFD6DCDE"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <CheckBox x:Name="CompactHudCheckBox"
                              Margin="0,12,0,0"
                              Style="{StaticResource PopupCheckBoxStyle}"
                              automation:AutomationProperties.AutomationId="CompactHudCheckBox"
                              Content="Compact focused HUD"
                              Foreground="#FFF0F4F5"
                              Checked="CompactHudCheckBox_OnChanged"
                              Unchecked="CompactHudCheckBox_OnChanged" />
                    <CheckBox x:Name="ShowPetNamesCheckBox"
                              Margin="0,8,0,0"
                              Style="{StaticResource PopupCheckBoxStyle}"
                              automation:AutomationProperties.AutomationId="ShowPetNamesCheckBox"
                              Content="Show pet names in the habitat"
                              Foreground="#FFF0F4F5"
                              Checked="ShowPetNamesCheckBox_OnChanged"
                              Unchecked="ShowPetNamesCheckBox_OnChanged" />
                    <CheckBox x:Name="ShowStatusSummaryCheckBox"
                              Margin="0,8,0,0"
                              Style="{StaticResource PopupCheckBoxStyle}"
                              automation:AutomationProperties.AutomationId="ShowStatusSummaryCheckBox"
                              Content="Show status summary text"
                              Foreground="#FFF0F4F5"
                              Checked="ShowStatusSummaryCheckBox_OnChanged"
                              Unchecked="ShowStatusSummaryCheckBox_OnChanged" />
                    <Border Margin="0,12,0,0"
                            Padding="10"
                            CornerRadius="10"
                            BorderBrush="#335E806E"
                            BorderThickness="1"
                            Background="#16221B">
                        <StackPanel>
                            <TextBlock Text="Always-on runtime supervisor"
                                       Foreground="#FFF0F4F5"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="RuntimeSupervisorStatusText"
                                       Margin="0,4,0,0"
                                       automation:AutomationProperties.AutomationId="RuntimeSupervisorStatusText"
                                       Text="Runtime supervisor: waiting for shell state."
                                       Foreground="#FFE7F8DF"
                                       FontSize="10"
                                       TextWrapping="Wrap" />
                            <CheckBox x:Name="RuntimeKillSwitchCheckBox"
                                      Margin="0,8,0,0"
                                      Style="{StaticResource PopupCheckBoxStyle}"
                                      automation:AutomationProperties.AutomationId="RuntimeKillSwitchCheckBox"
                                      Content="STOP all agent work immediately"
                                      Foreground="#FFFFC7C7"
                                      Checked="RuntimeKillSwitchCheckBox_OnChanged"
                                      Unchecked="RuntimeKillSwitchCheckBox_OnChanged" />
                            <CheckBox x:Name="RuntimeQuietModeCheckBox"
                                      Margin="0,8,0,0"
                                      Style="{StaticResource PopupCheckBoxStyle}"
                                      automation:AutomationProperties.AutomationId="RuntimeQuietModeCheckBox"
                                      Content="Quiet mode pauses agent work"
                                      Foreground="#FFF0F4F5"
                                      Checked="RuntimeQuietModeCheckBox_OnChanged"
                                      Unchecked="RuntimeQuietModeCheckBox_OnChanged" />
                            <CheckBox x:Name="RuntimePetOnlyModeCheckBox"
                                      Margin="0,8,0,0"
                                      Style="{StaticResource PopupCheckBoxStyle}"
                                      automation:AutomationProperties.AutomationId="RuntimePetOnlyModeCheckBox"
                                      Content="Pet-only mode hides agent tools"
                                      Foreground="#FFF0F4F5"
                                      Checked="RuntimePetOnlyModeCheckBox_OnChanged"
                                      Unchecked="RuntimePetOnlyModeCheckBox_OnChanged" />
                            <CheckBox x:Name="RuntimeBackgroundWorkAllowedCheckBox"
                                      Margin="0,8,0,0"
                                      Style="{StaticResource PopupCheckBoxStyle}"
                                      automation:AutomationProperties.AutomationId="RuntimeBackgroundWorkAllowedCheckBox"
                                      Content="Allow background agent previews"
                                      Foreground="#FFF0F4F5"
                                      Checked="RuntimeBackgroundWorkAllowedCheckBox_OnChanged"
                                      Unchecked="RuntimeBackgroundWorkAllowedCheckBox_OnChanged" />
                            <CheckBox x:Name="SchedulerEnabledCheckBox"
                                      Margin="0,8,0,0"
                                      Style="{StaticResource PopupCheckBoxStyle}"
