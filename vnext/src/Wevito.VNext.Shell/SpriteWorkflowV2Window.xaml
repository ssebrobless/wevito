<Window x:Class="Wevito.VNext.Shell.SpriteWorkflowV2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="Wevito Sprite Workflow V2"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        Background="#0D161C">
    <Window.Resources>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#16242D" />
            <Setter Property="BorderBrush" Value="#355061" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F8F8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="LaneBorder" TargetType="Border" BasedOn="{StaticResource PanelBorder}">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="#0E1A21" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Sprite Workflow V2"
                           Foreground="#F7FBFC"
                           FontSize="24"
                           FontWeight="Bold" />
                <TextBlock Text="Compact one-row workbench: source, runtime, candidate, proof. No generation. No automatic apply."
                           Foreground="#9FB7C4"
                           FontSize="12" />
            </StackPanel>
            <TextBlock x:Name="StatusText"
                       DockPanel.Dock="Right"
                       Foreground="#B7D7E4"
                       FontSize="12"
                       VerticalAlignment="Bottom"
                       Text="Loading..." />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Queue" Style="{StaticResource SectionLabel}" />
                        <TextBox x:Name="FilterTextBox"
                                 Margin="0,8,0,10"
                                 automation:AutomationProperties.AutomationId="SpriteWorkflowV2FilterTextBox"
                                 Background="#0D161C"
                                 Foreground="#F4FAFA"
                                 BorderBrush="#416176"
                                 TextChanged="FilterTextBox_OnTextChanged"
                                 ToolTip="Filter by species, age, gender, color, or family." />
                        <TextBlock x:Name="QueueSummaryText"
                                   Margin="0,0,0,8"
                                   Foreground="#9FB7C4"
                                   FontSize="10"
                                   Text="Showing capped queue." />
                    </StackPanel>
                    <ListBox x:Name="QueueListBox"
                             automation:AutomationProperties.AutomationId="SpriteWorkflowV2QueueListBox"
                             Background="#101C23"
                             Foreground="#EDF7F8"
                             BorderBrush="#294353"
                             SelectionChanged="QueueListBox_OnSelectionChanged"
                             DisplayMemberPath="DisplayName" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0"
                    Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock x:Name="SelectedRowHeaderText"
                                   Text="Select a row"
                                   Style="{StaticResource SectionLabel}" />
                        <TextBlock x:Name="SelectedRowSubheaderText"
                                   Foreground="#9FB7C4"
                                   FontSize="11"
                                   Text="No mutation controls are present in this phase." />
                        <TextBlock x:Name="SelectedTargetSummaryText"
                                   Margin="0,4,0,0"
                                   automation:AutomationProperties.AutomationId="SpriteWorkflowV2SelectedTargetSummaryText"
                                   Foreground="#E1D6A8"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Text="species | age | gender | color | family | expected frames | status" />
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <Button x:Name="ImportCandidateButton"
                                    Padding="8,4"
                                    Margin="0,0,8,0"
                                    automation:AutomationProperties.AutomationId="SpriteWorkflowV2ImportCandidateButton"
                                    Content="Import Candidate..."
                                    Click="ImportCandidateButton_OnClick" />
                            <Button x:Name="DryRunApplyButton"
                                    Padding="8,4"
                                    automation:AutomationProperties.AutomationId="SpriteWorkflowV2DryRunApplyButton"
                                    Content="Dry-Run Apply"
                                    Click="DryRunApplyButton_OnClick"
                                    IsEnabled="False" />
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBox x:Name="ApplyConfirmationTextBox"
                                     Width="260"
                                     Margin="0,0,8,0"
                                     automation:AutomationProperties.AutomationId="SpriteWorkflowV2ApplyConfirmationTextBox"
                                     Background="#0D161C"
                                     Foreground="#F4FAFA"
                                     BorderBrush="#416176"
                                     TextChanged="ApplyConfirmationTextBox_OnTextChanged"
                                     ToolTip="Type the exact selected row id to enable one-row apply." />
                            <Button x:Name="ApplyButton"
                                    Padding="8,4"
                                    Margin="0,0,8,0"
                                    automation:AutomationProperties.AutomationId="SpriteWorkflowV2ApplyButton"
                                    Content="Apply"
                                    Click="ApplyButton_OnClick"
                                    IsEnabled="False" />
                            <Button x:Name="RollbackButton"
                                    Padding="8,4"
                                    automation:AutomationProperties.AutomationId="SpriteWorkflowV2RollbackButton"
                                    Content="Rollback"
                                    Click="RollbackButton_OnClick"
                                    IsEnabled="False" />
                        </StackPanel>
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Columns="2"
                                 Rows="2">
                        <Border Style="{StaticResource LaneBorder}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Source authored / verified" Style="{StaticResource SectionLabel}" />
                                <Image x:Name="SourceStripImage" Margin="0,8,0,0" Stretch="Uniform" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource LaneBorder}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Runtime current" Style="{StaticResource SectionLabel}" />
                                <Image x:Name="RuntimeStripImage" Margin="0,8,0,0" Stretch="Uniform" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource LaneBorder}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Candidate" Style="{StaticResource SectionLabel}" />
                                <Grid Margin="0,8,0,0">
                                    <Image x:Name="CandidateStripImage" Stretch="Uniform" />
                                    <TextBlock x:Name="CandidatePlaceholderText"
                                               Foreground="#7892A0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="No candidate imported yet" />
                                </Grid>
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource LaneBorder}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Proof / rollback" Style="{StaticResource SectionLabel}" />
                                <TextBlock x:Name="ProofLaneText"
                                           Margin="0,8,0,0"
                                           Foreground="#BFD2DC"
                                           TextWrapping="Wrap"
                                           Text="Report only / no mutation yet. Import candidate, dry-run, type exact row id, then apply one exact row." />
                            </DockPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Validator Findings" Style="{StaticResource SectionLabel}" />
                        <TextBox x:Name="FindingsTextBox"
                                 Margin="0,8,0,0"
                                 Background="#0E1A21"
                                 Foreground="#F2F8F8"
                                 BorderBrush="#253D4C"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                        <TextBlock Text="Dry-Run Plan" Style="{StaticResource SectionLabel}" />
                        <TextBox x:Name="DryRunPreviewTextBox"
                                 Margin="0,8,0,0"
                                 Background="#0E1A21"
                                 Foreground="#F2F8F8"
                                 BorderBrush="#253D4C"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <TextBlock Text="Provenance" Style="{StaticResource SectionLabel}" />
                        <TextBox x:Name="ProvenanceTextBox"
                                 Margin="0,8,0,0"
                                 Background="#0E1A21"
                                 Foreground="#F2F8F8"
                                 BorderBrush="#253D4C"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas"
                                 FontSize="10"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
